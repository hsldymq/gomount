# gomount 配置文件示例
# 复制到 ~/.config/gomount_config.yaml 并根据需要修改

# ===============================
# SMB 挂载示例
# ===============================
mounts:
  - name: nas
    type: smb
    smb:
      addr: 192.168.1.100
      port: 445                      # 可选，默认445
      share_name: shared_folder
      username: user
      password: pass                 # 可选，会交互式提示
    mount_dir_path: /mnt/nas         # 必须：完整的挂载路径

  # -------------------------------
  # SSHFS 挂载示例
  # -------------------------------
  - name: dev-server
    type: sshfs
    ssh:
      host: dev.example.com          # ~/.ssh/config 中的别名或直接 hostname
    remote_path: /home/developer/projects
    mount_dir_path: /mnt/dev-projects  # 必须：完整的挂载路径

  # -------------------------------
  # SSHFS 通过跳板机（在 ~/.ssh/config 中配置 ProxyJump）
  # -------------------------------
  # ~/.ssh/config 示例:
  #   Host internal-server
  #     HostName 192.168.1.50
  #     User developer
  #     ProxyJump bastion.example.com
  #     IdentityFile ~/.ssh/id_rsa
  #
  # - name: internal-server
  #   type: sshfs
  #   ssh:
  #     host: internal-server
  #   remote_path: /data/shared
  #   mount_dir_path: /mnt/internal

  # -------------------------------
  # WebDAV 示例
  # -------------------------------
  - name: nextcloud
    type: webdav
    webdav:
      url: https://cloud.example.com/remote.php/dav/files/user/
      username: user
      password: pass
    mount_dir_path: /mnt/cloud       # 必须：完整的挂载路径
    options:
      file_mode: "0644"
      dir_mode: "0755"

# ===============================
# 工作区（Workspace）示例
# ===============================
workspaces:
  - name: company-dev
    description: "公司开发环境"
    mounts:
      - nas
      - dev-server

  - name: home-all
    description: "家里所有存储"
    mounts:
      - home-nas-via-ssh
      - nextcloud

# ===============================
# 配置说明
# ===============================
#
# 1. mount_dir_path 说明：
#    - 每个 mount 必须指定完整的挂载路径
#    - 支持 ~ 展开为用户主目录
#    - 示例: /mnt/nas, ~/Mounts/dev, /media/backup
#
# 2. 密码安全：
#    - 建议 omit password 字段，挂载时交互式输入
#    - 设置文件权限: chmod 600 ~/.config/gomount_config.yaml
#
# 3. SSH连接：
#    - ssh.host 支持 ~/.ssh/config 中的别名
#    - User、Port、IdentityFile、ProxyJump 等均由 ~/.ssh/config 管理
#
# 4. 驱动类型自动检测：
#    - 如果 type 省略，会根据字段自动推断：
#      * SSH + RemotePath → SSHFS
#      * WebDAV.URL → webdav
#      * SMBAddr → smb
